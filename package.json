{
  "name": "loganalyzer",
  "version": "1.0.0",
  "description": "Log analysis tool with charting, annotations, and keyword highlighting",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "pack": "npx electron-builder --win"
  },
  "build": {
    "appId": "com.danruwuai.loganalyzer",
    "productName": "LogAnalyzer",
    "directories": { "output": "dist" },
    "files": ["**/*", "!node_modules/.cache"],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "dependencies": {
    "echarts": "^6.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.25.0",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^4.0.0",
    "webpack": "^5.97.0",
    "webpack-cli": "^7.0.2"
  }
}
